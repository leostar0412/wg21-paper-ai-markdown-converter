# Copy to .env next to run_prompt.py or pass: --env-file /path/to/.env
# Claude Code (API route — avoids subscription-only /login in many setups)
ANTHROPIC_API_KEY=

# Optional
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=

# Cursor CLI (print mode / same auth family as ``agent acp`` — see cursor.com/docs/cli/acp)
# agent login
# CURSOR_API_KEY=
